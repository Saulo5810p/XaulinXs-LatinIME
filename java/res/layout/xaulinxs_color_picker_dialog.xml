<?xml version="1.0" encoding="utf-8"?>
<!-- XaulinXs Foundry: diálogo simples de escolha de cor por sliders RGB e
     campo hex, sem dependências externas de bibliotecas de color picker. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <View
        android:id="@+id/xaulinxs_color_preview"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/xaulinxs_color_hex_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/xaulinxs_color_picker_hex_hint"
        android:inputType="textCapCharacters"
        android:maxLength="6"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="R" />
    <SeekBar
        android:id="@+id/xaulinxs_seekbar_red"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="255" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="G" />
    <SeekBar
        android:id="@+id/xaulinxs_seekbar_green"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="255" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="B" />
    <SeekBar
        android:id="@+id/xaulinxs_seekbar_blue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="255" />

</LinearLayout>
