<?xml version="1.0" encoding="utf-8"?>
<!--
  XaulinXs Foundry: tela de personalização visual do teclado.
  Estilo Material simples (Switches, SeekBars, botões), consistente com o
  visual do LatinIME, sem dependências externas de bibliotecas de UI.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- ---- Papel de parede ---- -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/xaulinxs_section_wallpaper"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/xaulinxs_wallpaper_enable" />
            <Switch
                android:id="@+id/xaulinxs_switch_wallpaper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <Button
            android:id="@+id/xaulinxs_button_choose_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/xaulinxs_wallpaper_choose" />

        <ImageView
            android:id="@+id/xaulinxs_wallpaper_preview"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="@string/xaulinxs_wallpaper_choose" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22000000"
            android:layout_marginTop="20dp" />

        <!-- ---- Cores ---- -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/xaulinxs_section_colors"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/xaulinxs_keyboard_color_enable" />
            <Switch
                android:id="@+id/xaulinxs_switch_keyboard_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <Button
            android:id="@+id/xaulinxs_button_keyboard_color"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/xaulinxs_keyboard_color_choose" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/xaulinxs_key_text_color_enable" />
            <Switch
                android:id="@+id/xaulinxs_switch_key_text_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <Button
            android:id="@+id/xaulinxs_button_key_text_color"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/xaulinxs_key_text_color_choose" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22000000"
            android:layout_marginTop="20dp" />

        <!-- ---- Transparência e tamanho ---- -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/xaulinxs_section_size"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/xaulinxs_alpha_label"
            android:layout_marginTop="12dp" />
        <SeekBar
            android:id="@+id/xaulinxs_seekbar_alpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="255" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/xaulinxs_scale_label"
            android:layout_marginTop="12dp" />
        <!-- Range real é 0.5x-1.2x; a SeekBar usa passos inteiros de 0-70
             (mapeados em código para esse intervalo, já que SeekBar do
             framework não trabalha nativamente com float). -->
        <SeekBar
            android:id="@+id/xaulinxs_seekbar_scale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="70" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22000000"
            android:layout_marginTop="20dp" />

        <!-- ---- Fonte customizada ---- -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/xaulinxs_section_font"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/xaulinxs_font_current_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/xaulinxs_font_none" />

        <Button
            android:id="@+id/xaulinxs_button_choose_font"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/xaulinxs_font_choose" />

        <Button
            android:id="@+id/xaulinxs_button_reset_font"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/xaulinxs_font_reset" />

    </LinearLayout>
</ScrollView>
